# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/side-quest-maxxing

# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Webhook secret from Clerk Dashboard → Webhooks → Add Endpoint
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get these from https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Gamification Config ──────────────────────────────────────────────────────
# Minimum votes required for submission resolution
MIN_VOTES_REQUIRED=10
# Approval threshold (0-1) — 70%
APPROVAL_THRESHOLD=0.70
# Community quest approval upvote threshold
COMMUNITY_QUEST_UPVOTE_THRESHOLD=20
